# =============================================================================
# AW Client Report Portal — environment template
# Copy this file to `.env` and fill in values. `.env` is gitignored.
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# SQLite for V1. To switch to Postgres, change `provider` in
# prisma/schema.prisma to "postgresql" and set DATABASE_URL accordingly:
#   DATABASE_URL="postgresql://user:pass@host:5432/awportal?schema=public"
DATABASE_URL="file:./dev.db"

# ── NextAuth (Auth.js) ──────────────────────────────────────────────────────
# Generate a fresh secret with:
#   openssl rand -base64 32
AUTH_SECRET="replace-me-run-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# ── PDF generation ──────────────────────────────────────────────────────────
# URL Puppeteer navigates to (kept for future out-of-process renderer)
APP_URL="http://localhost:3000"

# Token any external PDF service would attach (unused while in-process)
PDF_SERVICE_TOKEN="local-dev-token"
