# Prisma / database
DATABASE_URL="file:./dev.db"

# NextAuth
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# App URL used by the PDF generator to navigate to print routes
APP_URL="http://localhost:3000"

# Internal token print routes accept (only meaningful when PDF service runs out-of-process)
PDF_SERVICE_TOKEN="local-dev-token"
